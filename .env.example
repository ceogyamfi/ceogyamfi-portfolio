# NeonDB — pooled connection for runtime
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15"

# NeonDB — direct (unpooled) connection for migrations
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""  # generate: openssl rand -base64 32

# Admin credentials (single hardcoded admin — no User table)
ADMIN_EMAIL="your@email.com"
ADMIN_PASSWORD_HASH=""  # generate: node -e "require('bcryptjs').hash('yourpassword',12).then(console.log)"

# Resend (contact form email delivery)
RESEND_API_KEY="re_xxxxxxxxxxxx"
RESEND_FROM_EMAIL="portfolio@yourdomain.com"
RESEND_TO_EMAIL="your@email.com"

# App
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
